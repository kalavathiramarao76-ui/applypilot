{
  "name": "@applypilot/extension",
  "displayName": "ApplyPilot - AI Job Application Copilot",
  "version": "1.0.0",
  "description": "AI-powered job application assistant. Detect jobs on LinkedIn & Indeed, get ATS scores, and tailor your resume with one click.",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package"
  },
  "dependencies": {
    "@applypilot/shared": "workspace:*",
    "@plasmohq/storage": "^1.11.0",
    "lucide-react": "^0.468.0",
    "plasmo": "^0.90.5",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwindcss": "^3.4.1"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.258",
    "@types/node": "^20.11.5",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "postcss": "^8.4.33",
    "typescript": "^5.3.3"
  },
  "manifest": {
    "permissions": ["storage", "activeTab", "sidePanel"],
    "host_permissions": [
      "https://www.linkedin.com/*",
      "https://www.indeed.com/*",
      "https://www.glassdoor.com/*"
    ]
  }
}
